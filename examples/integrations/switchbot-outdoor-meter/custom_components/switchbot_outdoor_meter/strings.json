{
  "config": {
    "flow_title": "{name}",
    "step": {
      "bluetooth_confirm": {
        "description": "Do you want to set up {name}?"
      },
      "user": {
        "description": "Choose a discovered SwitchBot Outdoor Meter to set up.",
        "data": {
          "address": "Device"
        }
      }
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "no_devices_found": "[%key:common::config_flow::abort::no_devices_found%]",
      "not_supported": "This device is not a supported SwitchBot Outdoor Meter."
    }
  },
  "entity": {
    "sensor": {
      "temperature": { "name": "[%key:component::sensor::entity_component::temperature::name%]" },
      "humidity": { "name": "[%key:component::sensor::entity_component::humidity::name%]" },
      "battery": { "name": "[%key:component::sensor::entity_component::battery::name%]" },
      "rssi": { "name": "[%key:component::sensor::entity_component::signal_strength::name%]" }
    }
  }
}
